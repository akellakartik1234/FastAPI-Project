# PostgreSQL connection (do not commit .env — it is gitignored)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/FastAPI_DB

# Comma-separated browser origins allowed to call the API (your deployed frontend URL(s))
CORS_ORIGINS=http://localhost:3000

# Copy the values you need into a file named `.env` in the project root
# (same directory as database.py and main.py).
